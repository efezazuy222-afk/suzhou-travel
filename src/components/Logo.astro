---
export interface LogoProps {
  href?: string;
  src?: string;
  alt?: string;
  className?: string;
}

const {
  href = "/",
  alt = "澜青旅行社",
  className = "text-white font-bold text-xl",
} = Astro.props;
---

<a href={href} class="inline-flex items-center gap-2">
  <span class={className}>澜青旅行社</span>
</a>